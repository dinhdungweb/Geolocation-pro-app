{% comment %}
  Geolocation Popup - Theme App Extension.
  This Liquid block stays intentionally small so Shopify homepage HTML caching
  does not freeze the redirect/block/popup runtime logic.
{% endcomment %}

<div id="geolocation-app-container" style="display: none;"></div>

<script>
(function() {
  'use strict';

  var LOADER_VERSION = '2026-04-24-runtime-loader';
  var THEME_BLOCK_ENABLED = {{ block.settings.enabled | json }};
  var shop = '{{ shop.permanent_domain }}';

  window.__GEOLOCATION_APP_CONFIG__ = {
    shop: shop,
    proxyUrl: '/apps/geolocation/config',
    analyticsUrl: '/apps/geolocation/analytics?shop=' + encodeURIComponent(shop),
    visitorCountry: '{{ request.country.iso_code | default: localization.country.iso_code | default: "" }}',
    themeBlockEnabled: THEME_BLOCK_ENABLED
  };

  window.GeolocationDebug = Object.assign(window.GeolocationDebug || {}, {
    loaderVersion: LOADER_VERSION,
    themeBlockEnabled: THEME_BLOCK_ENABLED
  });

  if (document.getElementById('geolocation-runtime-script')) return;

  var runtimeScript = document.createElement('script');
  runtimeScript.id = 'geolocation-runtime-script';
  runtimeScript.src = '/apps/geolocation/runtime?shop=' + encodeURIComponent(shop) + '&v=' + encodeURIComponent(LOADER_VERSION);
  runtimeScript.async = false;
  document.head.appendChild(runtimeScript);
})();
</script>

{% schema %}
{
  "name": "Geolocation Popup",
  "target": "body",
  "settings": [
    {
      "type": "paragraph",
      "content": "Configure redirect rules and popup settings in the Geolocation app admin."
    },
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Enable Geolocation Popup",
      "default": true
    }
  ]
}
{% endschema %}
