generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model RedirectRule {
  id              String   @id @default(uuid())
  shop            String
  name            String
  countryCodes    String   @default("")
  targetUrl       String   @default("")
  isActive        Boolean  @default(true)
  priority        Int      @default(0)
  ruleType        String   @default("redirect")
  scheduleEnabled Boolean  @default(false)
  startTime       String?
  endTime         String?
  daysOfWeek      String?
  timezone        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  ipAddresses     String   @default("")
  matchType       String   @default("country")
  redirectMode    String   @default("popup")
  pageTargetingType String   @default("all")
  pagePaths         String?  @db.Text

  @@index([shop])
  @@index([shop, matchType])
}

model Settings {
  id               String   @id @default(uuid())
  shop             String   @unique
  mode             String   @default("popup")
  template         String   @default("modal")
  popupTitle       String   @default("Would you like to switch to a local version?")
  popupMessage     String   @default("We noticed you are visiting from {country}. Would you like to go to {target}?")
  confirmBtnText   String   @default("Go now")
  cancelBtnText    String   @default("Stay here")
  popupBgColor     String   @default("#ffffff")
  popupTextColor   String   @default("#333333")
  popupBtnColor    String   @default("#007bff")
  blockedTitle     String   @default("Access Denied")
  blockedMessage   String   @default("We do not offer services in your country/region.")
  excludeBots      Boolean  @default(true)
  excludedIPs      String   @default("")
  cookieDuration   Int      @default(7)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  currentPlan      String   @default("free")
  emailSenderEmail String?  @default("noreply@geopro.bluepeaks.top")
  emailSenderName  String?  @default("Geo Admin")
  smtpHost         String?
  smtpPass         String?
  smtpPort         Int?
  smtpSecure       Boolean  @default(true)
  smtpUser         String?
  isEnabled        Boolean  @default(true)
  blockVpn         Boolean  @default(false)
}

model AnalyticsCountry {
  id          String   @id @default(uuid())
  shop        String
  date        DateTime
  countryCode String
  visitors    Int      @default(0)
  popupShown  Int      @default(0)
  redirected  Int      @default(0)
  blocked     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shop, date, countryCode])
  @@index([shop, date])
}

model AnalyticsRule {
  id             String   @id @default(uuid())
  shop           String
  date           DateTime
  ruleId         String
  ruleName       String
  seen           Int      @default(0)
  clickedYes     Int      @default(0)
  clickedNo      Int      @default(0)
  dismissed      Int      @default(0)
  autoRedirected Int      @default(0)
  blocked        Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([shop, date, ruleId])
  @@index([shop, date])
}

model MonthlyUsage {
  id              String   @id @default(uuid())
  shop            String
  yearMonth       String
  totalVisitors   Int      @default(0)
  redirected      Int      @default(0)
  blocked         Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  chargedVisitors Int      @default(0)
  popupShown      Int      @default(0)

  @@unique([shop, yearMonth])
  @@index([shop])
}

model VisitorLog {
  id          String   @id @default(uuid())
  shop        String
  ipAddress   String
  countryCode String?
  city        String?
  action      String
  ruleName    String?
  targetUrl   String?
  userAgent   String?
  timestamp   DateTime @default(now())

  @@index([shop, timestamp])
}

model AdminEmailLog {
  id        String   @id @default(uuid())
  shop      String
  type      String
  subject   String?
  status    String   @default("sent")
  error     String?
  createdAt DateTime @default(now())
  html      String?

  @@index([shop, type])
}

model Automation {
  id        String   @id @default(uuid())
  shop      String
  type      String
  subject   String?
  config    String   @default("[]")
  html      String   @default("")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String?  @default("Untitled Automation")

  @@unique([shop, type])
  @@index([shop])
}

model EmailTemplate {
  id        String   @id @default(uuid())
  shop      String
  name      String
  subject   String?
  config    String   @default("[]")
  html      String?  @default("")
  thumb     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
}

model Campaign {
  id          String    @id @default(uuid())
  shop        String
  name        String
  subject     String
  templateId  String?
  status      String    @default("draft")
  sentCount   Int       @default(0)
  openCount   Int       @default(0)
  clickCount  Int       @default(0)
  salesAmount Decimal   @default(0) @db.Decimal(12, 2)
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([shop, status])
}

model EmailBlacklist {
  id        String   @id @default(uuid())
  shop      String   @unique
  createdAt DateTime @default(now())
}
