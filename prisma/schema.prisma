generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model RedirectRule {
  id                String   @id @default(uuid())
  shop              String
  name              String
  countryCodes      String   @default("")
  targetUrl         String   @default("")
  isActive          Boolean  @default(true)
  priority          Int      @default(0)
  ruleType          String   @default("redirect")
  scheduleEnabled   Boolean  @default(false)
  startTime         String?
  endTime           String?
  daysOfWeek        String?
  timezone          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  ipAddresses       String   @default("")
  marketHandles     String   @default("")
  marketCountryCodes String  @default("")
  matchType         String   @default("country")
  stateCodes        String   @default("")
  redirectMode      String   @default("popup")
  pagePaths         String?
  pageTargetingType String   @default("all")

  @@index([shop])
  @@index([shop, matchType])
}

model Settings {
  id                 String   @id @default(uuid())
  shop               String   @unique
  mode               String   @default("popup")
  template           String   @default("modal")
  popupTitle         String   @default("Would you like to switch to a local version?")
  popupMessage       String   @default("We noticed you are visiting from {country}. Would you like to go to {target}?")
  confirmBtnText     String   @default("Go now")
  cancelBtnText      String   @default("Stay here")
  popupBgColor       String   @default("#ffffff")
  popupTextColor     String   @default("#333333")
  popupBtnColor      String   @default("#007bff")
  blockedTitle       String   @default("Access Denied")
  blockedMessage     String   @default("We do not offer services in your country/region.")
  blockedLogoUrl     String   @default("")
  blockedBgColor     String   @default("#f8fafc")
  blockedTextColor   String   @default("#0f172a")
  blockedAccentColor String   @default("#2563eb")
  blockedSupportText String   @default("Contact support")
  blockedSupportUrl  String   @default("")
  excludeBots        Boolean  @default(true)
  excludedIPs        String   @default("")
  cookieDuration     Int      @default(7)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  currentPlan        String   @default("free")
  emailSenderEmail   String?  @default("noreply@geopro.bluepeaks.top")
  emailSenderName    String?  @default("Geo Admin")
  smtpHost           String?
  smtpPass           String?
  smtpPort           Int?
  smtpSecure         Boolean  @default(true)
  smtpUser           String?
  isEnabled          Boolean  @default(true)
  blockVpn           Boolean  @default(false)
  allowUnlimitedPlan Boolean  @default(false)
  billingOverrideEnabled Boolean @default(false)
  billingOverridePlan String?
  billingOverrideReason String?
  customPlanEnabled  Boolean  @default(false)
  customPlanName     String   @default("Custom plan")
  customPlanPrice    Decimal  @default(79.99) @db.Decimal(10, 2)
  customPlanVisitorLimit Int?
  customPlanNoOverage Boolean @default(true)
  customPlanTrialDays Int     @default(3)
  billingPeriodKey String?
  billingPeriodStart DateTime?
  billingPeriodEnd DateTime?
  billingSubscriptionId String?
  billingUsageLineItemId String?
  billingPlanName String?
}

model AnalyticsCountry {
  id          String   @id @default(uuid())
  shop        String
  date        DateTime
  countryCode String
  visitors    Int      @default(0)
  popupShown  Int      @default(0)
  redirected  Int      @default(0)
  blocked     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shop, date, countryCode])
  @@index([shop, date])
}

model AnalyticsRule {
  id             String   @id @default(uuid())
  shop           String
  date           DateTime
  ruleId         String
  ruleName       String
  seen           Int      @default(0)
  clickedYes     Int      @default(0)
  clickedNo      Int      @default(0)
  dismissed      Int      @default(0)
  autoRedirected Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  blocked        Int      @default(0)

  @@unique([shop, date, ruleId])
  @@index([shop, date])
}

model MonthlyUsage {
  id              String   @id @default(uuid())
  shop            String
  yearMonth       String
  billingPeriodKey String
  billingPeriodStart DateTime?
  billingPeriodEnd DateTime?
  billingSubscriptionId String?
  billingUsageLineItemId String?
  totalVisitors   Int      @default(0)
  redirected      Int      @default(0)
  blocked         Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  chargedVisitors Int      @default(0)
  popupShown      Int      @default(0)

  @@unique([shop, billingPeriodKey])
  @@index([shop])
  @@index([shop, yearMonth])
  @@index([shop, billingPeriodStart])
  @@index([shop, billingPeriodEnd])
}

model UsageChargeAttempt {
  id                       String   @id @default(uuid())
  shop                     String
  billingPeriodKey         String
  billingUsageLineItemId   String?
  fromChargedVisitors      Int
  toChargedVisitors        Int
  overageVisitors          Int
  amount                   Decimal  @db.Decimal(10, 2)
  idempotencyKey           String   @unique
  shopifyUsageRecordId     String?
  status                   String   @default("pending")
  error                    String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([shop, billingPeriodKey, status])
  @@index([shop, status])
}

model JobLock {
  key         String   @id
  owner       String
  lockedUntil DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([lockedUntil])
}

model ShopCleanupJob {
  id          String    @id @default(uuid())
  shop        String
  reason      String
  status      String    @default("pending")
  attempts    Int       @default(0)
  lockedAt    DateTime?
  lastError   String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([shop, reason])
  @@index([status, lockedAt, createdAt])
  @@index([shop])
}

model BillableUsageEvent {
  id          String   @id @default(uuid())
  shop        String
  yearMonth   String
  billingPeriodKey String?
  eventKey    String   @unique
  ruleId      String?
  action      String
  countryCode String?
  path        String?
  ipHash      String
  createdAt   DateTime @default(now())

  @@index([shop, yearMonth])
  @@index([shop, billingPeriodKey])
  @@index([shop, createdAt])
  @@index([createdAt])
}

model BillableUsageActionEvent {
  id          String   @id @default(uuid())
  shop        String
  yearMonth   String
  billingPeriodKey String?
  eventKey    String
  action      String
  createdAt   DateTime @default(now())

  @@unique([eventKey, action])
  @@index([shop, yearMonth])
  @@index([shop, billingPeriodKey])
  @@index([shop, createdAt])
  @@index([createdAt])
}

model VisitorLog {
  id          String   @id @default(uuid())
  shop        String
  ipAddress   String
  countryCode String?
  regionCode  String?
  regionName  String?
  city        String?
  action      String
  ruleName    String?
  targetUrl   String?
  userAgent   String?
  timestamp   DateTime @default(now())
  path        String?

  @@index([shop, timestamp])
  @@index([shop, action, timestamp])
  @@index([shop, countryCode, timestamp])
  @@index([timestamp])
}

model StorefrontAnalyticsEventQueue {
  id            String   @id @default(uuid())
  shop          String
  type          String
  payload       Json
  status        String   @default("pending")
  attempts      Int      @default(0)
  nextAttemptAt DateTime @default(now())
  lockedAt      DateTime?
  lastError     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, nextAttemptAt, createdAt])
  @@index([status, lockedAt])
  @@index([shop, createdAt])
  @@index([createdAt])
}

model AdminEmailLog {
  id        String   @id @default(uuid())
  shop      String
  type      String
  subject   String?
  status    String   @default("sent")
  error     String?
  createdAt DateTime @default(now())
  html      String?

  @@index([shop, type])
}

model Automation {
  id        String   @id @default(uuid())
  shop      String
  type      String
  subject   String?
  config    String   @default("[]")
  html      String   @default("")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String?  @default("Untitled Automation")

  @@unique([shop, type])
  @@index([shop])
}

model EmailTemplate {
  id        String   @id @default(uuid())
  shop      String
  name      String
  subject   String?
  config    String   @default("[]")
  html      String?  @default("")
  thumb     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
}

model Campaign {
  id          String    @id @default(uuid())
  shop        String
  name        String
  subject     String
  templateId  String?
  status      String    @default("draft")
  sentCount   Int       @default(0)
  openCount   Int       @default(0)
  clickCount  Int       @default(0)
  salesAmount Decimal   @default(0) @db.Decimal(12, 2)
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  html        String?

  @@index([shop, status])
}

model EmailBlacklist {
  id        String   @id @default(uuid())
  shop      String   @unique
  createdAt DateTime @default(now())
}
